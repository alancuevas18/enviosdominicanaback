APP_NAME="Envios Dominicana"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/Santo_Domingo

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_DO

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=envios_dominicana
DB_USERNAME=root
DB_PASSWORD=secret

# ─── Root User (created by RootUserSeeder) ───────────────────────────────────
ROOT_EMAIL=root@enviosdominicana.com
ROOT_PASSWORD=SuperSecret2025!

# ─── Session / Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database

QUEUE_CONNECTION=database

# ─── Broadcasting (Pusher) ───────────────────────────────────────────────────
# Set to 'pusher' in production. Use 'log' for local dev without Pusher.
BROADCAST_CONNECTION=log

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=us2
# PUSHER_HOST=127.0.0.1   # uncomment when using local Soketi instead
# PUSHER_PORT=6001
# PUSHER_SCHEME=http

# ─── Filesystem / S3 ─────────────────────────────────────────────────────────
FILESYSTEM_DISK=local
# Change to s3 in production
# FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=envios-dominicana
AWS_USE_PATH_STYLE_ENDPOINT=false

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@enviosdominicana.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Web Push (VAPID) ────────────────────────────────────────────────────────
# Generate with: php artisan webpush:vapid
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT="mailto:admin@enviosdominicana.com"

# ─── Sanctum ─────────────────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,127.0.0.1,127.0.0.1:8000

# ─── API ─────────────────────────────────────────────────────────────────────
API_VERSION_STRATEGY=uri

# ─── Redis (optional, for high-traffic production) ───────────────────────────
# REDIS_CLIENT=phpredis
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

VITE_APP_NAME="${APP_NAME}"
